# Whisper Live Transcription Server — Environment Configuration
# Copy this file to .env and update values for your environment.
# CLI flags override .env values when both are provided.
# Both server.py and ollama_processor.py load this file automatically.

# ── Server ────────────────────────────────────────────────────
WHISPER_HOST=0.0.0.0
HTTPS_PORT=9090
WSS_PORT=9091
CONTROL_PORT=9092

# Set to true to run without TLS (local dev only, not for mobile)
USE_HTTP=false

# ── TLS Certificates (mkcert recommended) ─────────────────────
# Paths relative to server.py, or absolute paths
SSL_CERT=cert.pem
SSL_KEY=key.pem

# ── Whisper Model ─────────────────────────────────────────────
# Used for --download-models. Options: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# ── Ollama ────────────────────────────────────────────────────
# Used by both server.py (control channel) and ollama_processor.py (standalone)
OLLAMA_HOST=http://192.168.3.16
OLLAMA_MODEL=phi4
OLLAMA_TIMEOUT=300

# Set to true to disable the Ollama control server entirely
OLLAMA_DISABLED=false

# ── HuggingFace Model Downloads ───────────────────────────────
# Requires: pip install hf-transfer
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_MAX_CONNECTIONS=16
